<%
  const heroBreadcrumbItems = typeof breadcrumbItems !== 'undefined' ? breadcrumbItems : [];
  const heroButtons = typeof buttons !== 'undefined' ? buttons : [];
  const heroImage = typeof image !== 'undefined' ? image : '';
  const heroImageAlt = typeof imageAlt !== 'undefined' ? imageAlt : title;
%>
<section class="page-hero py-5">
  <div class="container">
    <% if (heroBreadcrumbItems.length) { %>
      <%- include('./breadcrumb', { items: heroBreadcrumbItems }) %>
    <% } %>
    <div class="row align-items-center g-4">
      <div class="col-lg-7">
        <% if (eyebrow) { %><span class="eyebrow"><%= eyebrow %></span><% } %>
        <h1 class="display-5 fw-bold mt-3"><%= title %></h1>
        <% if (summary) { %><div class="lead page-hero-copy mt-3"><%- summary %></div><% } %>
        <% if (heroButtons.length) { %>
          <div class="d-flex flex-wrap gap-3 mt-4">
            <% heroButtons.forEach((button, index) => { %>
              <a href="<%= button.href %>" class="btn <%= index === 0 ? 'btn-sdg' : 'btn-outline-sdg' %>"><%= button.label %></a>
            <% }) %>
          </div>
        <% } %>
      </div>
      <div class="col-lg-5">
        <div class="hero-media-shell">
          <% if (heroImage) { %>
            <img src="<%= heroImage %>" alt="<%= heroImageAlt %>" class="img-fluid rounded-4 hero-image" />
          <% } else { %>
            <div class="placeholder-image rounded-4 hero-placeholder">Section image placeholder</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>
