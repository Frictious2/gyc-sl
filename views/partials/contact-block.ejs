<div class="contact-block card border-0 shadow-sm">
  <div class="card-body p-4">
    <h2 class="h4 mb-3">Contact & Office Information</h2>
    <p><%= contactSettings.contact_intro %></p>
    <div class="row g-3">
      <div class="col-md-6">
        <div class="contact-meta-card">
          <h3 class="h6"><i class="bi bi-geo-alt-fill"></i> Address</h3>
          <p class="mb-0"><%- contactSettings.contact_address.replace(/\n/g, '<br />') %></p>
        </div>
      </div>
      <div class="col-md-6">
        <div class="contact-meta-card">
          <h3 class="h6"><i class="bi bi-telephone-fill"></i> Phone</h3>
          <p class="mb-0"><%- contactSettings.contact_phone.replace(/\n/g, '<br />') %></p>
        </div>
      </div>
      <div class="col-md-6">
        <div class="contact-meta-card">
          <h3 class="h6"><i class="bi bi-envelope-fill"></i> Email</h3>
          <p class="mb-0"><%- contactSettings.contact_email.replace(/\n/g, '<br />') %></p>
        </div>
      </div>
      <div class="col-md-6">
        <div class="contact-meta-card">
          <h3 class="h6"><i class="bi bi-clock-fill"></i> Office Hours</h3>
          <p class="mb-0"><%- contactSettings.contact_hours.replace(/\n/g, '<br />') %></p>
        </div>
      </div>
    </div>
    <div class="contact-map-shell mt-4">
      <% if (contactSettings.contact_map_embed && !contactSettings.contact_map_embed.startsWith('[')) { %>
        <div class="ratio ratio-16x9"><%- contactSettings.contact_map_embed %></div>
      <% } else { %>
        <div class="placeholder-image rounded-4 map-placeholder">Map embed placeholder</div>
      <% } %>
    </div>
  </div>
</div>
