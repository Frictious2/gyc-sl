<article class="gallery-card h-100">
  <% if (item.file_path) { %>
    <img src="<%= item.file_path %>" alt="<%= item.alt_text || item.title %>" class="gallery-media" />
  <% } else { %>
    <div class="placeholder-image rounded-4 gallery-media">Gallery image placeholder</div>
  <% } %>
  <div class="p-3">
    <div class="d-flex justify-content-between gap-2 mb-2">
      <span class="badge badge-soft"><%= item.category || 'Gallery' %></span>
      <% if (item.slug) { %><small class="text-muted"><%= item.slug %></small><% } %>
    </div>
    <h3 class="h6 mb-1"><%= item.title %></h3>
    <% if (item.caption) { %><p class="small text-muted mb-0"><%= item.caption %></p><% } %>
  </div>
</article>
