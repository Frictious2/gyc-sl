<article class="sdg-card h-100">
  <% if (post.featured_image_path) { %>
    <img src="<%= post.featured_image_path %>" alt="<%= post.featured_image_alt || post.title %>" class="card-media mb-3" />
  <% } else { %>
    <div class="placeholder-image rounded-4 card-media mb-3">News image placeholder</div>
  <% } %>
  <div class="d-flex flex-wrap gap-2 mb-3">
    <span class="badge sdg-badge"><%= post.category %></span>
    <% if (post.published_at) { %><span class="badge badge-soft"><%= String(post.published_at).slice(0, 10) %></span><% } %>
  </div>
  <h3 class="h5"><%= post.title %></h3>
  <p><%= post.excerpt || post.summary || '' %></p>
  <a href="/news/<%= post.slug %>" class="text-decoration-none">Read more</a>
</article>
