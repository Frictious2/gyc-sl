<article class="sdg-card h-100 accent-<%= accentClass || 'blue' %>">
  <span class="badge sdg-badge"><%= program.badge || program.slug || 'Program' %></span>
  <h3 class="h5 mt-3"><%= program.title %></h3>
  <p><%= program.short_description || program.summary || '' %></p>
  <a href="/programs/<%= program.slug %>" class="stretched-link text-decoration-none">Explore program</a>
</article>
