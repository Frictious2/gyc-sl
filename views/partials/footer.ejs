<%
  const localsData = typeof locals !== 'undefined' ? locals : {};
  const footer = localsData.footerSettings || {};
  const splitLinks = (value) =>
    String(value || '')
      .split('\n')
      .map((line) => line.trim())
      .filter(Boolean)
      .map((line) => {
        const [label, href] = line.split('|');
        return { label: (label || '').trim(), href: (href || '#').trim() };
      });
%>
<footer class="site-footer pt-5 pb-4 mt-5">
  <div class="container">
    <div class="row g-4">
      <div class="col-lg-3">
        <%- include('site-brand', { brandHref: '/', brandTitle: branding.name, brandShowTagline: true }) %>
        <p><%- String(footer.footer_about || 'GYC Sierra Leone').replace(/\n/g, '<br />') %></p>
        <div class="d-flex gap-2 social-row">
          <span class="social-pill"><i class="bi bi-facebook"></i></span>
          <span class="social-pill"><i class="bi bi-twitter-x"></i></span>
          <span class="social-pill"><i class="bi bi-instagram"></i></span>
          <span class="social-pill"><i class="bi bi-linkedin"></i></span>
          <span class="social-pill"><i class="bi bi-youtube"></i></span>
        </div>
      </div>
      <div class="col-6 col-lg-2">
        <h6>Quick Links</h6>
        <ul class="list-unstyled footer-links">
          <% splitLinks(footer.footer_quick_links).forEach((link) => { %>
            <li><a href="<%= link.href %>"><%= link.label %></a></li>
          <% }) %>
        </ul>
      </div>
      <div class="col-6 col-lg-2">
        <h6>Programs</h6>
        <ul class="list-unstyled footer-links">
          <% splitLinks(footer.footer_program_links).forEach((link) => { %>
            <li><a href="<%= link.href %>"><%= link.label %></a></li>
          <% }) %>
        </ul>
      </div>
      <div class="col-6 col-lg-2">
        <h6>Get Involved</h6>
        <ul class="list-unstyled footer-links">
          <% splitLinks(footer.footer_get_involved_links).forEach((link) => { %>
            <li><a href="<%= link.href %>"><%= link.label %></a></li>
          <% }) %>
        </ul>
      </div>
      <div class="col-6 col-lg-3">
        <h6>Contact</h6>
        <p class="mb-0"><%- String(footer.footer_contact_summary || '').replace(/\n/g, '<br />') %></p>
      </div>
    </div>
    <div class="footer-bottom d-flex flex-column flex-md-row justify-content-between gap-2 mt-4 pt-4 border-top">
      <small>&copy; <%= currentYear %> <%= footer.footer_bottom_text || 'Global Youth Counterpart for Sustainable Development Sierra Leone. All Rights Reserved.' %></small>
      <small>Privacy Policy | Terms of Use | Sitemap</small>
    </div>
  </div>
</footer>
