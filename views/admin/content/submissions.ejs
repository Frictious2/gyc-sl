<%- include('../../partials/flash-messages') %>

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table align-middle">
        <thead>
          <tr>
            <% Object.keys(records[0] || { id: '', created_at: '' }).forEach((key) => { %>
              <% if (key !== 'deleted_at' && key !== 'updated_at') { %><th><%= key %></th><% } %>
            <% }) %>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% records.forEach((record) => { %>
            <tr>
              <% Object.entries(record).forEach(([key, value]) => { %>
                <% if (key !== 'deleted_at' && key !== 'updated_at') { %>
                  <td><%= value %></td>
                <% } %>
              <% }) %>
              <td>
                <form action="/admin/submissions/<%= type %>/<%= record.id %>/delete" method="post">
                  <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
          <% if (!records.length) { %>
            <tr><td colspan="99" class="text-muted">No submissions yet.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
