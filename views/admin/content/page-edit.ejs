<%- include('../../partials/flash-messages') %>
<%
  const pageData = page || {};
  const pageSections = Array.isArray(pageData.sections) ? pageData.sections : [];
  const mediaList = Array.isArray(mediaItems) ? mediaItems : [];
%>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h2 class="h5 mb-1">Page settings</h2>
        <p class="text-muted mb-0"><code><%= pageData.route_path || pageData.slug || 'Unknown route' %></code></p>
      </div>
      <a href="/admin/pages" class="btn btn-outline-secondary btn-sm">Back to pages</a>
    </div>

    <form action="/admin/pages/<%= pageData.id %>" method="post" class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Page title</label>
        <input class="form-control" name="title" value="<%= pageData.title || '' %>" />
      </div>
      <div class="col-md-6">
        <label class="form-label">Hero image</label>
        <div class="d-flex gap-2">
          <select class="form-select" id="hero_image_id" name="hero_image_id">
            <option value="">No image selected</option>
            <% mediaList.forEach((media) => { %>
              <option value="<%= media.id %>" <%= String(pageData.hero_image_id || '') === String(media.id) ? 'selected' : '' %>><%= media.title || media.file_name || `Media #${media.id}` %></option>
            <% }) %>
          </select>
          <button class="btn btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#mediaPickerModal" data-media-target="hero_image_id">Pick</button>
        </div>
      </div>
      <div class="col-12">
        <label class="form-label">Hero title</label>
        <input class="form-control" name="hero_title" value="<%= pageData.hero_title || '' %>" />
      </div>
      <div class="col-12">
        <label class="form-label">Hero subtitle</label>
        <textarea class="form-control" name="hero_subtitle" rows="3"><%= pageData.hero_subtitle || '' %></textarea>
      </div>
      <div class="col-md-4">
        <label class="form-label">Status</label>
        <select class="form-select" name="status">
          <option value="published" <%= pageData.status === 'published' ? 'selected' : '' %>>Published</option>
          <option value="draft" <%= pageData.status === 'draft' ? 'selected' : '' %>>Draft</option>
          <option value="archived" <%= pageData.status === 'archived' ? 'selected' : '' %>>Archived</option>
        </select>
      </div>
      <div class="col-md-4 d-flex align-items-end">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="is_published" id="pagePublished" <%= pageData.is_published ? 'checked' : '' %> />
          <label class="form-check-label" for="pagePublished">Publish page</label>
        </div>
      </div>
      <div class="col-12">
        <button class="btn btn-sdg" type="submit">Save page</button>
      </div>
    </form>
  </div>
</div>

<div class="row g-4">
  <% if (!pageSections.length) { %>
    <div class="col-12">
      <div class="alert alert-warning mb-0">No sections were found for this page. This usually means the production database is missing seeded page sections or the schema is out of date.</div>
    </div>
  <% } %>
  <% pageSections.forEach((section) => { 
    const sectionItems = Array.isArray(section.items) ? section.items : [];
    const sectionMedia = Array.isArray(section.media) ? section.media : [];
  %>
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
              <h3 class="h6 mb-1"><%= section.section_key %></h3>
              <p class="text-muted mb-0">Edit text, buttons, media, sort order, and publish state.</p>
            </div>
            <span class="badge text-bg-light"><%= section.layout_style || 'default' %></span>
          </div>

          <form action="/admin/sections/<%= section.id %>" method="post" class="row g-3">
            <input type="hidden" name="page_id" value="<%= pageData.id %>" />
            <div class="col-md-6">
              <label class="form-label">Title</label>
              <input class="form-control" name="title" value="<%= section.title || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Subtitle</label>
              <input class="form-control" name="subtitle" value="<%= section.subtitle || '' %>" />
            </div>
            <div class="col-12">
              <label class="form-label">Body text</label>
              <textarea class="form-control" name="body" rows="4"><%= section.body || '' %></textarea>
            </div>
            <div class="col-md-3">
              <label class="form-label">Primary button label</label>
              <input class="form-control" name="cta_label" value="<%= section.cta_label || '' %>" />
            </div>
            <div class="col-md-3">
              <label class="form-label">Primary button link</label>
              <input class="form-control" name="cta_link" value="<%= section.cta_link || '' %>" />
            </div>
            <div class="col-md-3">
              <label class="form-label">Secondary button label</label>
              <input class="form-control" name="secondary_cta_label" value="<%= section.secondary_cta_label || '' %>" />
            </div>
            <div class="col-md-3">
              <label class="form-label">Secondary button link</label>
              <input class="form-control" name="secondary_cta_link" value="<%= section.secondary_cta_link || '' %>" />
            </div>
            <div class="col-md-5">
              <label class="form-label">Section image</label>
              <div class="d-flex gap-2">
                <select class="form-select" id="section-image-<%= section.id %>" name="image_id">
                  <option value="">No image selected</option>
                  <% mediaList.forEach((media) => { %>
                    <option value="<%= media.id %>" <%= String(section.image_id || '') === String(media.id) ? 'selected' : '' %>><%= media.title || media.file_name || `Media #${media.id}` %></option>
                  <% }) %>
                </select>
                <button class="btn btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#mediaPickerModal" data-media-target="section-image-<%= section.id %>">Pick</button>
              </div>
            </div>
            <div class="col-md-2">
              <label class="form-label">Sort order</label>
              <input class="form-control" name="sort_order" type="number" value="<%= section.sort_order || 0 %>" />
            </div>
            <div class="col-md-3">
              <label class="form-label">Status</label>
              <select class="form-select" name="status">
                <option value="published" <%= section.status === 'published' ? 'selected' : '' %>>Published</option>
                <option value="draft" <%= section.status === 'draft' ? 'selected' : '' %>>Draft</option>
                <option value="archived" <%= section.status === 'archived' ? 'selected' : '' %>>Archived</option>
              </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="is_published" id="published-<%= section.id %>" <%= section.is_published ? 'checked' : '' %> />
                <label class="form-check-label" for="published-<%= section.id %>">Publish</label>
              </div>
            </div>
            <div class="col-12">
              <button class="btn btn-sdg" type="submit">Save section</button>
            </div>
          </form>

          <hr class="my-4" />

          <div class="row g-4">
            <div class="col-lg-6">
              <h4 class="h6 mb-3">Section Items</h4>
              <% if (sectionItems.length) { %>
                <% sectionItems.forEach((item) => { %>
                  <div class="border rounded-4 p-3 mb-3">
                    <form action="/admin/section-items/<%= item.id %>" method="post" class="row g-2">
                      <input type="hidden" name="page_id" value="<%= pageData.id %>" />
                      <div class="col-md-6">
                        <label class="form-label">Item type</label>
                        <input class="form-control" name="item_type" value="<%= item.item_type || 'card' %>" />
                      </div>
                      <div class="col-md-6">
                        <label class="form-label">Sort order</label>
                        <input class="form-control" type="number" name="sort_order" value="<%= item.sort_order || 0 %>" />
                      </div>
                      <div class="col-12">
                        <label class="form-label">Title</label>
                        <input class="form-control" name="title" value="<%= item.title || '' %>" />
                      </div>
                      <div class="col-12">
                        <label class="form-label">Subtitle</label>
                        <input class="form-control" name="subtitle" value="<%= item.subtitle || '' %>" />
                      </div>
                      <div class="col-12">
                        <label class="form-label">Body</label>
                        <textarea class="form-control" name="body" rows="3"><%= item.body || '' %></textarea>
                      </div>
                      <div class="col-md-6">
                        <label class="form-label">Link label</label>
                        <input class="form-control" name="link_label" value="<%= item.link_label || '' %>" />
                      </div>
                      <div class="col-md-6">
                        <label class="form-label">Link URL</label>
                        <input class="form-control" name="link_url" value="<%= item.link_url || '' %>" />
                      </div>
                      <div class="col-12">
                        <button class="btn btn-outline-secondary btn-sm" type="submit">Save item</button>
                      </div>
                    </form>
                    <form action="/admin/section-items/<%= item.id %>/delete" method="post" class="mt-2">
                      <input type="hidden" name="page_id" value="<%= pageData.id %>" />
                      <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                    </form>
                  </div>
                <% }) %>
              <% } else { %>
                <p class="text-muted small">No section items yet for this section.</p>
              <% } %>
              <form action="/admin/section-items" method="post" class="row g-2">
                <input type="hidden" name="page_id" value="<%= pageData.id %>" />
                <input type="hidden" name="section_id" value="<%= section.id %>" />
                <div class="col-md-6">
                  <label class="form-label">Item type</label>
                  <input class="form-control" name="item_type" value="card" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Sort order</label>
                  <input class="form-control" type="number" name="sort_order" value="0" />
                </div>
                <div class="col-12">
                  <label class="form-label">Title</label>
                  <input class="form-control" name="title" />
                </div>
                <div class="col-12">
                  <label class="form-label">Subtitle</label>
                  <input class="form-control" name="subtitle" />
                </div>
                <div class="col-12">
                  <label class="form-label">Body</label>
                  <textarea class="form-control" name="body" rows="3"></textarea>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Image</label>
                  <div class="d-flex gap-2">
                    <select class="form-select" id="section-item-image-<%= section.id %>" name="image_id">
                      <option value="">No image selected</option>
                      <% mediaList.forEach((media) => { %>
                        <option value="<%= media.id %>"><%= media.title || media.file_name || `Media #${media.id}` %></option>
                      <% }) %>
                    </select>
                    <button class="btn btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#mediaPickerModal" data-media-target="section-item-image-<%= section.id %>">Pick</button>
                  </div>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Publish</label>
                  <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" name="is_published" checked />
                    <label class="form-check-label">Published</label>
                  </div>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Link label</label>
                  <input class="form-control" name="link_label" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Link URL</label>
                  <input class="form-control" name="link_url" />
                </div>
                <div class="col-12">
                  <button class="btn btn-outline-secondary btn-sm" type="submit">Add section item</button>
                </div>
              </form>
            </div>

            <div class="col-lg-6">
              <h4 class="h6 mb-3">Section Media</h4>
              <% if (sectionMedia.length) { %>
                <div class="table-responsive mb-3">
                  <table class="table table-sm align-middle">
                    <thead>
                      <tr>
                        <th>Role</th>
                        <th>Asset</th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody>
                      <% sectionMedia.forEach((mediaLink) => { %>
                        <tr>
                          <td><%= mediaLink.media_role || 'gallery' %></td>
                          <td>
                            <%= mediaLink.media_title || mediaLink.media_file_name || (mediaLink.media_id ? `Missing media #${mediaLink.media_id}` : 'Missing media record') %>
                          </td>
                          <td>
                            <form action="/admin/section-media/<%= mediaLink.id %>/delete" method="post">
                              <input type="hidden" name="page_id" value="<%= pageData.id %>" />
                              <button class="btn btn-outline-danger btn-sm" type="submit">Remove</button>
                            </form>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } else { %>
                <p class="text-muted small">No media assets linked to this section yet.</p>
              <% } %>
              <form action="/admin/section-media" method="post" class="row g-2">
                <input type="hidden" name="page_id" value="<%= pageData.id %>" />
                <input type="hidden" name="section_id" value="<%= section.id %>" />
                <div class="col-md-6">
                  <label class="form-label">Media asset</label>
                  <select class="form-select" name="media_id">
                    <option value="">Select media</option>
                    <% mediaList.forEach((media) => { %>
                      <option value="<%= media.id %>"><%= media.title || media.file_name || `Media #${media.id}` %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Role</label>
                  <select class="form-select" name="media_role">
                    <option value="gallery">gallery</option>
                    <option value="hero">hero</option>
                    <option value="supporting">supporting</option>
                    <option value="background">background</option>
                  </select>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Caption</label>
                  <input class="form-control" name="caption" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Alt text override</label>
                  <input class="form-control" name="alt_text" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Sort order</label>
                  <input class="form-control" type="number" name="sort_order" value="0" />
                </div>
                <div class="col-12">
                  <button class="btn btn-outline-secondary btn-sm" type="submit">Link media asset</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<%- include('../../partials/admin/media-picker-modal', { mediaItems: mediaList }) %>
