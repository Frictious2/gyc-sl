<%- include('../../partials/page-hero', {
  eyebrow: page?.title || 'Our Team',
  title: page?.hero_title || 'Meet the People Behind GYC',
  summary: page?.hero_subtitle || '',
  image: page?.hero_image_path,
  imageAlt: page?.hero_image_alt,
  breadcrumbItems: [
    { label: 'About', href: '/about' },
    { label: 'Team' }
  ]
}) %>

<%
  const teamSections = Array.isArray(page?.sections) ? page.sections : [];
  const leadershipSection = teamSections.find((section) => section.section_key === 'leadership-team');
  const boardSection = teamSections.find((section) => section.section_key === 'board');
  const districtsSection = teamSections.find((section) => section.section_key === 'district-coordinators');
%>

<section class="py-5">
  <div class="container">
    <div class="section-heading mb-4">
      <span class="eyebrow"><%= leadershipSection?.subtitle || 'Leadership Team' %></span>
      <h2 class="display-6 fw-bold mt-3"><%= leadershipSection?.title || 'Youth energy with professional expertise' %></h2>
      <% if (leadershipSection?.body) { %><div class="section-subtitle mt-3"><%- leadershipSection.body %></div><% } %>
    </div>
    <div class="row g-4">
      <% teamBundle.team.forEach((person) => { %>
        <div class="col-md-6 col-xl-3">
          <%- include('../../partials/team-card', { person }) %>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="py-5 bg-soft">
  <div class="container">
    <div class="section-heading mb-4">
      <span class="eyebrow"><%= boardSection?.subtitle || 'Board of Directors' %></span>
      <h2 class="display-6 fw-bold mt-3"><%= boardSection?.title || 'Strategic oversight and governance' %></h2>
      <% if (boardSection?.body) { %><div class="section-subtitle mt-3"><%- boardSection.body %></div><% } %>
    </div>
    <div class="row g-4">
      <% teamBundle.board.forEach((person) => { %>
        <div class="col-md-6 col-xl-3">
          <%- include('../../partials/team-card', { person }) %>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="section-heading mb-4">
      <span class="eyebrow"><%= districtsSection?.subtitle || 'District Coordinators' %></span>
      <h2 class="display-6 fw-bold mt-3"><%= districtsSection?.title || 'Grassroots reach through a volunteer network' %></h2>
      <% if (districtsSection?.body) { %><div class="section-subtitle mt-3"><%- districtsSection.body %></div><% } %>
    </div>
    <div class="row g-4">
      <% teamBundle.districts.forEach((person) => { %>
        <div class="col-md-6 col-xl-4">
          <%- include('../../partials/team-card', { person }) %>
        </div>
      <% }) %>
    </div>
  </div>
</section>
