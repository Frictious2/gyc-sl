<%- include('../../partials/page-hero', {
  eyebrow: post.category,
  title: post.title,
  summary: post.excerpt || post.summary || '',
  image: post.featured_image_path,
  imageAlt: post.featured_image_alt,
  breadcrumbItems: [
    { label: 'News & Events', href: '/news' },
    { label: post.title }
  ]
}) %>

<section class="py-5">
  <div class="container">
    <div class="sdg-card article-card">
      <div class="d-flex flex-wrap gap-2 mb-3">
        <% if (post.published_at) { %><span class="badge badge-soft"><%= String(post.published_at).slice(0, 10) %></span><% } %>
        <% if (post.author_name) { %><span class="badge badge-soft"><%= post.author_name %></span><% } %>
      </div>
      <p class="mb-0"><%= post.body %></p>
    </div>
  </div>
</section>
