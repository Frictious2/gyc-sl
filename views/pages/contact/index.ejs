<%- include('../../partials/page-hero', {
  eyebrow: page?.title || 'Contact',
  title: page?.hero_title || 'Get in Touch',
  summary: page?.hero_subtitle || '',
  image: page?.hero_image_path,
  imageAlt: page?.hero_image_alt,
  breadcrumbItems: [{ label: 'Contact' }]
}) %>

<section class="py-5">
  <div class="container">
    <div class="row g-4">
      <div class="col-lg-5">
        <div class="sdg-card h-100">
          <h2 class="h4">Contact Form</h2>
          <%- include('../../partials/flash-messages') %>
          <form action="/contact" method="post" class="row g-3 needs-validation" novalidate>
            <div class="col-12">
              <input class="form-control <%= formErrors.full_name ? 'is-invalid' : '' %>" name="full_name" value="<%= oldInput.full_name || '' %>" placeholder="Full Name *" required />
              <%- include('../../partials/form-field-error', { field: 'full_name' }) %>
            </div>
            <div class="col-md-6">
              <input class="form-control <%= formErrors.email ? 'is-invalid' : '' %>" name="email" type="email" value="<%= oldInput.email || '' %>" placeholder="Email Address *" required />
              <%- include('../../partials/form-field-error', { field: 'email' }) %>
            </div>
            <div class="col-md-6"><input class="form-control" name="phone" value="<%= oldInput.phone || '' %>" placeholder="Phone Number" /></div>
            <div class="col-12"><input class="form-control" name="organization" value="<%= oldInput.organization || '' %>" placeholder="Organization (optional)" /></div>
            <div class="col-12">
              <input class="form-control <%= formErrors.subject ? 'is-invalid' : '' %>" name="subject" value="<%= oldInput.subject || '' %>" placeholder="Subject *" required />
              <%- include('../../partials/form-field-error', { field: 'subject' }) %>
            </div>
            <div class="col-12">
              <textarea class="form-control <%= formErrors.message ? 'is-invalid' : '' %>" rows="6" name="message" placeholder="Message *" required><%= oldInput.message || '' %></textarea>
              <%- include('../../partials/form-field-error', { field: 'message' }) %>
            </div>
            <div class="col-12"><button class="btn btn-sdg" type="submit">Send Message</button></div>
          </form>
        </div>
      </div>
      <div class="col-lg-7">
        <%- include('../../partials/contact-block', { contactSettings }) %>
      </div>
    </div>
  </div>
</section>
