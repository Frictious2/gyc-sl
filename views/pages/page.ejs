<%
  const pathParts = page.route_path.split('/').filter(Boolean);
  const breadcrumbItems = pathParts.map((part, index) => ({
    label: part.replace(/-/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase()),
    href: index === pathParts.length - 1 ? null : `/${pathParts.slice(0, index + 1).join('/')}`
  }));
%>

<%- include('../partials/page-hero', {
  eyebrow: page.title,
  title: page.hero_title,
  summary: page.hero_subtitle,
  image: page.hero_image_path,
  imageAlt: page.hero_image_alt,
  breadcrumbItems
}) %>

<section class="py-5">
  <div class="container">
    <div class="row g-4">
      <% page.sections.forEach((section) => { %>
        <div class="<%= section.layout_style === 'content' ? 'col-lg-12' : 'col-lg-6' %>">
          <div class="sdg-card h-100">
            <% if (section.image_path) { %>
              <img src="<%= section.image_path %>" alt="<%= section.image_alt || section.title %>" class="card-media mb-3" />
            <% } else if (section.layout_style === 'feature' || section.layout_style === 'gallery') { %>
              <div class="placeholder-image rounded-4 card-media mb-3">Section image placeholder</div>
            <% } %>
            <h2 class="h4"><%= section.title %></h2>
            <% if (section.subtitle) { %><div class="section-subtitle"><%- section.subtitle %></div><% } %>
            <div class="mb-0"><%- section.body || '' %></div>
            <% if (section.cta_label && section.cta_link) { %>
              <div class="mt-4 d-flex flex-wrap gap-2">
                <a href="<%= section.cta_link %>" class="btn btn-sdg btn-sm"><%= section.cta_label %></a>
                <% if (section.secondary_cta_label && section.secondary_cta_link) { %>
                  <a href="<%= section.secondary_cta_link %>" class="btn btn-outline-sdg btn-sm"><%= section.secondary_cta_label %></a>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<% if (page.route_path === '/get-involved/volunteer') { %>
  <section class="py-5 bg-soft">
    <div class="container">
      <div class="sdg-card">
        <h2 class="h4">Volunteer Application Form</h2>
        <%- include('../partials/flash-messages') %>
        <form action="/volunteer-application" method="post" class="row g-3 needs-validation" novalidate>
          <div class="col-md-6">
            <input class="form-control <%= formErrors.full_name ? 'is-invalid' : '' %>" name="full_name" value="<%= oldInput.full_name || '' %>" placeholder="Full Name *" required />
            <%- include('../partials/form-field-error', { field: 'full_name' }) %>
          </div>
          <div class="col-md-6">
            <input class="form-control <%= formErrors.email ? 'is-invalid' : '' %>" name="email" type="email" value="<%= oldInput.email || '' %>" placeholder="Email Address *" required />
            <%- include('../partials/form-field-error', { field: 'email' }) %>
          </div>
          <div class="col-md-6"><input class="form-control" name="phone" value="<%= oldInput.phone || '' %>" placeholder="Phone Number" /></div>
          <div class="col-md-6"><input class="form-control" name="district" value="<%= oldInput.district || '' %>" placeholder="District" /></div>
          <div class="col-12"><input class="form-control" name="interests" value="<%= oldInput.interests || '' %>" placeholder="Areas of interest" /></div>
          <div class="col-12"><textarea class="form-control" name="motivation" rows="5" placeholder="Why do you want to volunteer?"><%= oldInput.motivation || '' %></textarea></div>
          <div class="col-12"><button class="btn btn-sdg" type="submit">Apply to Volunteer</button></div>
        </form>
      </div>
    </div>
  </section>
<% } %>

<% if (page.route_path === '/get-involved/partner') { %>
  <section class="py-5 bg-soft">
    <div class="container">
      <div class="sdg-card">
        <h2 class="h4">Partnership Inquiry Form</h2>
        <%- include('../partials/flash-messages') %>
        <form action="/partnership-inquiry" method="post" class="row g-3 needs-validation" novalidate>
          <div class="col-md-6">
            <input class="form-control <%= formErrors.organisation_name ? 'is-invalid' : '' %>" name="organisation_name" value="<%= oldInput.organisation_name || '' %>" placeholder="Organisation Name *" required />
            <%- include('../partials/form-field-error', { field: 'organisation_name' }) %>
          </div>
          <div class="col-md-6">
            <input class="form-control <%= formErrors.contact_name ? 'is-invalid' : '' %>" name="contact_name" value="<%= oldInput.contact_name || '' %>" placeholder="Contact Name *" required />
            <%- include('../partials/form-field-error', { field: 'contact_name' }) %>
          </div>
          <div class="col-md-6">
            <input class="form-control <%= formErrors.email ? 'is-invalid' : '' %>" name="email" type="email" value="<%= oldInput.email || '' %>" placeholder="Email Address *" required />
            <%- include('../partials/form-field-error', { field: 'email' }) %>
          </div>
          <div class="col-md-6"><input class="form-control" name="phone" value="<%= oldInput.phone || '' %>" placeholder="Phone Number" /></div>
          <div class="col-md-6"><input class="form-control" name="partnership_type" value="<%= oldInput.partnership_type || '' %>" placeholder="Partnership Type" /></div>
          <div class="col-12"><textarea class="form-control" name="message" rows="5" placeholder="Tell us about the partnership opportunity"><%= oldInput.message || '' %></textarea></div>
          <div class="col-12"><button class="btn btn-sdg" type="submit">Submit Inquiry</button></div>
        </form>
      </div>
    </div>
  </section>
<% } %>
