<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Admin' %> | <%= appName %></title>
    <link rel="icon" type="image/svg+xml" href="<%= branding.logoPath %>" />
    <link rel="shortcut icon" href="<%= branding.logoPath %>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/admin.css" />
  </head>
  <body class="admin-body">
    <div class="admin-shell d-flex">
      <%- include('../partials/admin/sidebar') %>
      <div class="admin-main flex-grow-1">
        <%- include('../partials/admin/topbar') %>
        <div class="container-fluid py-4">
          <%- body %>
        </div>
      </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
    <script src="/js/admin.js"></script>
  </body>
</html>
