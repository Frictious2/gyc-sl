<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= (pageMeta && pageMeta.title) || title || appName %> | <%= appName %></title>
    <meta name="description" content="<%= (pageMeta && pageMeta.description) || '' %>" />
    <meta name="keywords" content="<%= (pageMeta && pageMeta.keywords) || '' %>" />
    <meta property="og:title" content="<%= (pageMeta && pageMeta.ogTitle) || (pageMeta && pageMeta.title) || title || appName %>" />
    <meta property="og:description" content="<%= (pageMeta && pageMeta.ogDescription) || (pageMeta && pageMeta.description) || '' %>" />
    <% if (pageMeta && pageMeta.ogImage) { %>
      <meta property="og:image" content="<%= pageMeta.ogImage %>" />
    <% } %>
    <% if (pageMeta && pageMeta.canonicalUrl) { %>
      <link rel="canonical" href="<%= pageMeta.canonicalUrl %>" />
    <% } %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('../partials/header') %>
    <%- include('../partials/navbar') %>
    <main class="site-main">
      <%- body %>
    </main>
    <%- include('../partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
  </body>
</html>
